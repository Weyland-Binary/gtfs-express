{$DOMAIN} {
    # Maintenance mode: set MAINTENANCE=true in .env.production.local, then
    # re-apply the caddy service (docker compose ... up -d caddy). Every route
    # answers 503 with a static English page; crawlers see Retry-After and
    # keep the site indexed. TLS/ACME is unaffected (handled before routing).
    @maintenance `{env.MAINTENANCE} == "true"`
    handle @maintenance {
        header Cache-Control "no-store"
        header Retry-After "3600"
        header Content-Type "text/html; charset=utf-8"
        respond <<HTML
            <!DOCTYPE html>
            <html lang="en">
            <head>
              <meta charset="utf-8">
              <meta name="viewport" content="width=device-width, initial-scale=1">
              <title>Scheduled maintenance — GTFS Express</title>
              <style>
                body { margin: 0; min-height: 100vh; display: flex; align-items: center;
                       justify-content: center; background: #0f172a; color: #e2e8f0;
                       font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif; }
                main { max-width: 30rem; padding: 2rem; text-align: center; }
                .badge { font-size: 3rem; line-height: 1; }
                h1 { font-size: 1.4rem; margin: 1rem 0 0.5rem; }
                p { color: #94a3b8; line-height: 1.6; margin: 0.25rem 0; }
              </style>
            </head>
            <body>
              <main>
                <div class="badge">&#128679;</div>
                <h1>We&rsquo;ll be right back</h1>
                <p>GTFS Express is undergoing scheduled maintenance.</p>
                <p>Your data is safe. Please check back in a few minutes.</p>
              </main>
            </body>
            </html>
            HTML 503
    }

    route /api/gtfs/upload-stats {
        basic_auth {
            {$STATS_USER} {$STATS_HASH}
        }
        reverse_proxy frontend:80
    }

    handle_path /stats/* {
        @ws {
            header Connection *Upgrade*
            header Upgrade websocket
        }
        @not_ws {
            not {
                header Connection *Upgrade*
                header Upgrade websocket
            }
        }
        basicauth @not_ws {
            {$STATS_USER} {$STATS_HASH}
        }
        handle @ws {
            reverse_proxy goaccess:7890
        }
        handle @not_ws {
            root * /stats
            file_server
        }
    }

    handle {
        reverse_proxy frontend:80
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    }

    log {
        output file /logs/access.log {
            roll_size 10mb
            roll_keep 5
        }
        format json
    }
}

www.{$DOMAIN} {
    redir https://{$DOMAIN}{uri} 301
}

gtfs-explorer.org {
    redir https://{$DOMAIN}{uri} 301
}

www.gtfs-explorer.org {
    redir https://{$DOMAIN}{uri} 301
}
