# Port du serveur
PORT=3004

# Admin dashboard secret. Required in production. If empty, /admin/* returns 503.
# Use a long random string (e.g. `openssl rand -hex 32`).
ADMIN_TOKEN=

# HMAC secret used to anonymize IP addresses in event logs and beta-usage records.
# Required in production: the API aborts at startup if NODE_ENV=production and
# this is left at the default (a fallback to ADMIN_TOKEN exists but should not
# be relied upon). Use a long random string (e.g. `openssl rand -hex 32`).
IP_HASH_SECRET=

# CORS : origines autorisées (séparées par des virgules)
ALLOWED_ORIGINS=http://localhost:3000

# Rate Limiting (global / upload / sample loader)
# 3000 req/h leaves headroom for an active editing session: 200+ stop edits
# in a single sitting + a few revalidations are normal for a transit operator
# polishing a feed. Tighten in production via the env var if abuse is observed.
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX_REQUESTS=3000
RATE_LIMIT_MAX_UPLOADS=20
RATE_LIMIT_SAMPLE_WINDOW_MS=900000
RATE_LIMIT_MAX_SAMPLES=5

# Gestion des sessions
SESSION_CLEANUP_AGE_MS=7200000
MAX_SESSIONS=50

# Environnement (development | production)
NODE_ENV=development

# 🚧 Beta gate — limited beta access on edit-mode entry points
# - BETA_GATE_DISABLED=true   → middleware no-op (recommandé en dev local)
# - BETA_GATE_DISABLED=false  → lit BETA_CODES_PATH ; sans codes.json valide,
#                               toute requête /edit/enter renvoie 403 BETA_CONFIG_ERROR
# Pour la dev locale : laisser DISABLED=true OU créer `beta/codes.json` à
# partir de `beta/codes.example.json`.
BETA_GATE_DISABLED=true
# Chemins par défaut : `<api>/beta/codes.json` et `<api>/beta/usage.jsonl`.
# Surcharger uniquement si stockage hors arbo (NFS, secret manager…).
# BETA_CODES_PATH=
# BETA_USAGE_PATH=

# 🤖 NL2SQL — génération de requêtes SQL à partir du langage naturel via
# l'API Anthropic Claude. Feature réservée aux beta testeurs (gate identique
# à /edit/enter). Le system prompt contient le schéma SQLite des 15 tables
# GTFS, les contraintes (heures > 24:00:00, FK ON UPDATE CASCADE, ...) et
# les requêtes analytiques préinstallées comme exemples few-shot.
#
# - NL2SQL_ENABLED=true   → endpoint POST /gtfs/sql/nl2sql actif + bouton
#                           "Generate from natural language" affiché côté UI
# - NL2SQL_ENABLED=false  → endpoint renvoie 503, bouton masqué (kill switch)
# - NL2SQL_MODEL          → modèle Claude (défaut claude-haiku-4-5 pour le
#                           coût ; passer claude-sonnet-4-6 ou claude-opus-4-7
#                           pour des requêtes plus complexes)
# - ANTHROPIC_API_KEY     → clé API Anthropic (https://console.anthropic.com)
NL2SQL_ENABLED=true
NL2SQL_MODEL=claude-haiku-4-5
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_WITH_YOUR_KEY

# AI cost guard — three-tier sliding-window limiter (services/aiCostLimiter.js)
# applied to /sql/nl2sql AND /sql/nl2sql-chat. All caps are sliding windows.
#   - NL2SQL_RATE_LIMIT           per-code hourly cap on the one-shot endpoint
#   - NL2SQL_CHAT_RATE_LIMIT      per-code hourly cap on the chat endpoint
#   - NL2SQL_DAILY_LIMIT_PER_CODE per-code 24h cap shared across both endpoints
#   - NL2SQL_DAILY_BUDGET_TOTAL   global 24h kill-switch shared across all codes
# At Claude Haiku ~1¢/req: 100/code/day = ~1€/code/day; 500 global = ~5€/day max.
NL2SQL_RATE_LIMIT=30
NL2SQL_DAILY_LIMIT_PER_CODE=100
NL2SQL_DAILY_BUDGET_TOTAL=500
