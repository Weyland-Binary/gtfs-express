{
  "name": "GTFS-EXPRESS-API",
  "version": "1.0.0",
  "description": "GTFS Express — API for parsing, editing and validating GTFS files.",
  "main": "src/app.js",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=10"
  },
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "jest --runInBand --forceExit",
    "test:coverage": "jest --runInBand --forceExit --coverage"
  },
  "keywords": [
    "gtfs",
    "api",
    "transport"
  ],
  "author": "Weyland-Binary",
  "license": "AGPL-3.0-only",
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "testTimeout": 30000
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "archiver": "^7.0.1",
    "better-sqlite3": "^12.11.1",
    "body-parser": "^1.20.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.1",
    "dotenv": "^17.2.3",
    "express": "^4.19.2",
    "express-fileupload": "^1.5.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.2.0",
    "libphonenumber-js": "^1.13.6",
    "swagger-ui-express": "^5.0.1",
    "unzipper": "^0.12.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.2.2"
  }
}
