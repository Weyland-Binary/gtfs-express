# Local development overrides for `docker compose up --build`.
#
#   copy .env.example .env     (Windows)
#   cp .env.example .env       (macOS/Linux)
#
# then edit the values. The root `.env` is gitignored — NEVER commit it.
# Every flag below defaults to its secure/off value when absent, so CI and
# production are unaffected by this file's existence.

# ── Corporate proxy escape hatches (build-time) ─────────────────────────────
# Set BOTH to true when an SSL-intercepting proxy breaks apk (Alpine
# packages) and curl (MobilityData validator JAR download) during the image
# build. Local use only.
APK_INSECURE=true
CURL_INSECURE=true
# The NeTEx converter build needs crates.io over TLS — behind the same kind
# of proxy, skip it (the app simply hides the NeTEx export option):
NETEX_ENABLED=false

# ── AI companion (runtime) ──────────────────────────────────────────────────
# Required to see ANY AI surface (chat FAB, "Repair with AI", Ask AI...).
#ANTHROPIC_API_KEY=sk-ant-...
NL2SQL_ENABLED=true
NL2SQL_CHAT_ENABLED=true
#NL2SQL_CHAT_MODEL=claude-sonnet-4-6
#NL2SQL_FREE_MESSAGES_PER_SESSION=5

# Skip beta codes entirely in local dev (edit mode + AI without a key).
BETA_GATE_DISABLED=true

# ── Corporate proxy: container -> api.anthropic.com (runtime, DEV ONLY) ─────
# If the chat shows "Connection error.", the API container cannot reach
# Anthropic. Behind an SSL-INTERCEPTING (transparent) proxy:
#NODE_TLS_REJECT_UNAUTHORIZED=0
# Behind an EXPLICIT proxy (Node 24 routes fetch through it):
#NODE_USE_ENV_PROXY=1
#HTTPS_PROXY=http://proxy.corp:8080
#NO_PROXY=localhost,127.0.0.1,api
