# =============================================================================
# Configuration de production — GTFS Express
# Copier en .env.production.local sur le serveur, ne jamais commiter ce fichier
#
# Convention :
#   [REQUIS]    — doit être défini ; pas de défaut, le service ne démarre pas correctement sans
#   [OPTIONNEL] — a un défaut sain dans docker-compose.prod.yml ; ne surcharger que si besoin
# =============================================================================

# ── Domaine & TLS (Caddy + CORS) ─────────────────────────────────────────────
# [REQUIS] Nom de domaine public (sans protocole ni slash final)
DOMAIN=gtfs.votre-domaine.com

# ── Mode maintenance ──────────────────────────────────────────────────────────
# [OPTIONNEL] défaut : false. À true, Caddy répond 503 sur TOUTES les routes
# avec une page statique « We'll be right back » (anglais) + Retry-After: 3600
# (les crawlers conservent l'indexation). Le site et l'API restent intacts
# derrière — seul le routage est court-circuité. TLS/ACME non affecté.
# Appliquer le changement (recrée uniquement le conteneur Caddy, ~2 s) :
#   docker compose -f docker-compose.prod.yml --env-file .env.production.local up -d caddy
# MAINTENANCE=false

# ── Statistiques GoAccess (/stats/) ──────────────────────────────────────────
# [REQUIS] Identifiant HTTP Basic Auth pour accéder à la page de stats
STATS_USER=admin
# [REQUIS] Hash bcrypt du mot de passe GoAccess
# Générer : docker run --rm caddy:2-alpine caddy hash-password --plaintext VOTRE_MOT_DE_PASSE
# IMPORTANT : doubler chaque $ du hash (ex: $2a$ → $$2a$$) — Docker Compose interprète les $
STATS_HASH=

# ── Admin dashboard (#admin) ──────────────────────────────────────────────────
# [REQUIS] Token secret pour l'endpoint /api/gtfs/admin/*.
# Laisser vide pour désactiver complètement la page admin.
# Sert aussi de sel HMAC pour l'anonymisation des IP dans les logs.
ADMIN_TOKEN=

# ── Anonymisation des IP — audit logs (usage.jsonl, _events.jsonl) ───────────
# [REQUIS en prod] Sel HMAC-SHA256 utilisé par eventLogger.js pour hasher les IP
# avant écriture dans les fichiers d'audit (`_events.jsonl`, `beta/usage.jsonl`).
# Doit être DISTINCT de ADMIN_TOKEN pour permettre la rotation indépendante des
# deux secrets (cf. CLAUDE.md règle stricte #9).
# Si absent ou laissé au sel par défaut en production, l'API logge
# "FATAL: IP_HASH_SECRET must be set in production..." et fait `process.exit(1)`
# au démarrage — le container ne démarrera pas.
# Générer : `openssl rand -hex 32` (≥32 caractères aléatoires recommandés).
IP_HASH_SECRET=replace-with-32-byte-random-secret

# ── Beta gate ─────────────────────────────────────────────────────────────────
# [OPTIONNEL] défaut : false (gate ACTIF — exige un code beta valide via le
# header X-Beta-Code). Mettre à true en dev pour ouvrir l'édition + le chat IA
# à tout le monde sans codes.json.
# Le code source : process.env.BETA_GATE_DISABLED === "true" → undefined = false.
BETA_GATE_DISABLED=false

# ── NL2SQL — Assistant IA SQL ─────────────────────────────────────────────────
# [REQUIS si NL2SQL_ENABLED=true] Clé API Anthropic
# https://console.anthropic.com
ANTHROPIC_API_KEY=<YOUR_ANTHROPIC_API_KEY>

# [OPTIONNEL] défaut : true — passer à false pour désactiver le bouton + endpoint
NL2SQL_ENABLED=true
# [OPTIONNEL] défaut : claude-haiku-4-5 — rapide et économique pour la prod
# Alternatives : claude-sonnet-4-6 (plus précis), claude-opus-4-7 (max qualité)
NL2SQL_MODEL=claude-haiku-4-5

# ── NL2SQL Chat — Agent IA conversationnel (FAB beta-only) ───────────────────
# Bouton flottant en bas à gauche → ouvre un drawer chat multi-tour. Réutilise
# ANTHROPIC_API_KEY ci-dessus + le même gate beta que /sql/nl2sql. Lecture
# seule : les mutations sont déviées vers la console SQL en mode brouillon.
# Streaming SSE token-par-token (compression désactivée pour cette route).
#
# [OPTIONNEL] défaut : false — passer à true pour activer le FAB côté front
NL2SQL_CHAT_ENABLED=false
# [OPTIONNEL] défaut : claude-sonnet-4-6 — le chat est le compagnon de
# réparation (raisonnement multi-tables, brouillons de correction) : Sonnet
# par défaut pour la fiabilité ; le one-shot NL2SQL reste sur NL2SQL_MODEL
# NL2SQL_CHAT_MODEL=claude-sonnet-4-6
# [OPTIONNEL] défaut : 5 — essai gratuit anonyme du chat (porte d'entrée
# d'achat). 0 = désactivé (gate beta strict). Borné par session, par IP
# hashée/jour (ci-dessous) et par le budget global NL2SQL_DAILY_BUDGET_TOTAL.
# NL2SQL_FREE_MESSAGES_PER_SESSION=5
# [OPTIONNEL] défaut : 15 — plafond quotidien par IP hashée (anti-recyclage
# de sessions anonymes)
# NL2SQL_FREE_MESSAGES_PER_IP_DAY=15
# [OPTIONNEL] défaut : 30 — messages par heure et par code beta (sliding window)
# NL2SQL_CHAT_RATE_LIMIT=30
# [OPTIONNEL] défaut : beta/chat-usage.jsonl — log d'usage séparé du beta usage
# NL2SQL_CHAT_USAGE_PATH=/data/beta/chat-usage.jsonl

# ── AI cost guard (one-shot /sql/nl2sql + chat /sql/nl2sql-chat) ──────────────
# Three-tier sliding-window limiter wired in services/aiCostLimiter.js.
# All caps are PER 24h or PER 1h sliding (not calendar-based).
#
# [OPTIONNEL] défaut : 30 — messages/h/code beta sur /sql/nl2sql (one-shot).
# NL2SQL_RATE_LIMIT=30
#
# [OPTIONNEL] défaut : 100 — requêtes/24h/code beta, partagé entre les 2 endpoints.
# À ~1¢/requête (Claude Haiku) → ~1€/jour/code maximum, prévisible par testeur.
# NL2SQL_DAILY_LIMIT_PER_CODE=100
#
# [OPTIONNEL] défaut : 500 — kill-switch global 24h tous codes/endpoints confondus.
# Plafond financier dur : ~5€/jour maximum quel que soit le scénario d'abus.
# Un code compromis ou un client scripté ne pourra jamais dépasser ce seuil.
# ⚠️ Ce plafond global n'est JAMAIS relevé par tier/code — il s'applique à
# tout le monde, détenteurs de clé beta compris. C'est le garde-fou opérateur.
# NL2SQL_DAILY_BUDGET_TOTAL=500

# ── Tier beta — caps IA confortables pour les détenteurs d'un code valide ────
# Appliqués dès qu'un X-Beta-Code valide est présent (classé par
# middleware/betaContext). Un code peut surcharger ces valeurs individuellement
# via `quota` dans codes.json (ex : { "quota": { "dailyAi": 5000 } }).
# Plus généreux que le tier sans clé, mais TOUJOURS bornés (chaque code garde
# un plafond € prévisible) et toujours sous le budget global ci-dessus.
#
# [OPTIONNEL] défaut : 300 — requêtes IA/h/code beta (vs 30 sans clé)
# BETA_NL2SQL_RATE_LIMIT=300
# [OPTIONNEL] défaut : 2000 — requêtes IA/24h/code beta (vs 100 sans clé)
# BETA_NL2SQL_DAILY_LIMIT_PER_CODE=2000

# ── Rate limiting API ─────────────────────────────────────────────────────────
# Les valeurs ci-dessous sont les DÉFAUTS du compose. Ne les inclure dans ce
# fichier que si vous souhaitez les surcharger.
#
# [OPTIONNEL] défaut : 3600000  — fenêtre rate limit globale (ms)
# RATE_LIMIT_WINDOW_MS=3600000
#
# [OPTIONNEL] défaut : 500 (compose) / 3000 (recommandé en phase beta) —
# requêtes max / IP / fenêtre. Le défaut compose-prod (500) est conservateur ;
# une session d'édition active sur un GTFS réel atteint facilement 500-1000
# requêtes (PATCH/POST par stop), surtout si plusieurs membres d'une même
# équipe partagent une IP via NAT bureau. 3000 donne du confort sans ouvrir
# la porte à un abus manifeste.
# RATE_LIMIT_MAX_REQUESTS=3000
#
# [OPTIONNEL] défaut : 10  — uploads max / IP / fenêtre
# RATE_LIMIT_MAX_UPLOADS=10
#
# [OPTIONNEL] défaut : 900000  — fenêtre rate limit sample loader (ms)
# RATE_LIMIT_SAMPLE_WINDOW_MS=900000
#
# [OPTIONNEL] défaut : 5  — samples max / IP / fenêtre
# RATE_LIMIT_MAX_SAMPLES=5
#
# [OPTIONNEL] défaut : 5  — revalidations max / min (CPU-bound : validateur complet)
# RATE_LIMIT_MAX_REVALIDATE=5

# ── Tier beta — caps requêtes/uploads/SQL pour les détenteurs d'un code ──────
# Appliqués dès qu'un X-Beta-Code valide est présent. Chaque détenteur obtient
# son propre bucket (clé `beta:<code>`, isolé de son IP) avec un plafond relevé
# mais borné. Le trafic sans clé garde les caps ci-dessus. Aucun moyen de
# DÉSACTIVER un limiter pour les beta — uniquement de relever le plafond.
#
# [OPTIONNEL] défaut : 30000 — requêtes/h/code beta (vs RATE_LIMIT_MAX_REQUESTS sans clé)
# BETA_RATE_LIMIT_MAX_REQUESTS=30000
# [OPTIONNEL] défaut : 200 — uploads/h/code beta (vs RATE_LIMIT_MAX_UPLOADS sans clé)
# BETA_RATE_LIMIT_MAX_UPLOADS=200
# [OPTIONNEL] défaut : 600 — requêtes SQL/min/code beta (vs 60 sans clé)
# BETA_RATE_LIMIT_MAX_SQL=600
# [OPTIONNEL] défaut : 30 — revalidations/min/code beta (vs 5 sans clé)
# BETA_RATE_LIMIT_MAX_REVALIDATE=30

# ── Sessions ──────────────────────────────────────────────────────────────────
# [OPTIONNEL] défaut : 3600000  — TTL de nettoyage des sessions (ms)
# SESSION_CLEANUP_AGE_MS=3600000
#
# [OPTIONNEL] défaut : 20  — sessions simultanées max en RAM (plafond DUR global,
# détenteurs de clé beta compris). Avec 2G allouée au container :
# 20 × ~100MB = ~2GB. Réduire si gros GTFS, augmenter si le VPS a plus de RAM.
# MAX_SESSIONS=20
#
# [OPTIONNEL] défaut : = MAX_SESSIONS (aucune réservation) — sous-pool réservé
# au trafic SANS clé. Le mettre PLUS BAS que MAX_SESSIONS garantit que les
# utilisateurs anonymes ne peuvent jamais saturer toute la capacité : les slots
# restants (MAX_SESSIONS - MAX_KEYLESS_SESSIONS) sont réservés aux détenteurs
# d'un code beta. Ex : MAX_SESSIONS=20 + MAX_KEYLESS_SESSIONS=12 → 8 slots
# garantis pour les beta même quand le serveur est plein.
# MAX_KEYLESS_SESSIONS=12
